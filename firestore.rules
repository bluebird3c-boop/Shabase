rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'description', 'imageUrl', 'sellerId', 'createdAt']) &&
             (data.keys().size() >= 6 && data.keys().size() <= 10) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1500000 &&
             (data.get('category', null) == null || (data.category is string && data.category.size() <= 100)) &&
             (data.get('location', null) == null || (data.location is string && data.location.size() <= 200)) &&
             (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 50)) &&
             (data.get('sellerName', null) == null || (data.sellerName is string && data.sellerName.size() <= 200)) &&
             data.sellerId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidProductUpdate(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1500000 &&
             (data.get('category', null) == null || (data.category is string && data.category.size() <= 100)) &&
             (data.get('location', null) == null || (data.location is string && data.location.size() <= 200)) &&
             (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 50)) &&
             (data.get('sellerName', null) == null || (data.sellerName is string && data.sellerName.size() <= 200)) &&
             data.sellerId == existing().sellerId; // Must not change sellerId
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (existing().buyerId == request.auth.uid || existing().sellerId == request.auth.uid);
      allow create: if isSignedIn() && incoming().buyerId == request.auth.uid;
      allow update: if isSignedIn(); // Relaxed for the prototype
    }

    match /transactions/{txId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable list

      // list query for 'my products' requires the client to explicitly filter by sellerId
      // In this app, everyone can read all products.

      allow create: if isSignedIn() &&
                    isValidId(productId) &&
                    isValidProduct(incoming());

      allow update: if isSignedIn() &&
                    isValidId(productId) &&
                    (
                      (existing().sellerId == request.auth.uid &&
                       isValidProductUpdate(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['title', 'price', 'description', 'imageUrl', 'category', 'location', 'phone', 'sellerName', 'ratingCount', 'averageRating'])) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['ratingCount', 'averageRating']))
                    );

      allow delete: if isSignedIn() &&
                    isValidId(productId) &&
                    existing().sellerId == request.auth.uid; // Must be the owner
    }
  }
}
